# Copy to .env (gitignored) and fill in. See docs/MANUAL-SETUP.md for how to
# generate each value and register the first OAuth apps (GitHub, Google).

# Postgres backing store for Nango's own vault.
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=change-me-generate-a-real-password
NANGO_DB_NAME=nango
NANGO_DB_PORT=5435
NANGO_REDIS_PORT=6381

# 256-bit key, base64-encoded. Generate with: openssl rand -base64 32
# Immutable once real connections exist - back it up outside git.
NANGO_ENCRYPTION_KEY=

# API bearer secret lifeos-api uses to call Nango. Generate with: openssl rand -hex 32
NANGO_SECRET_KEY_DEV=
NANGO_SECRET_KEY_PROD=

# Basic-auth for the Nango dashboard (http://localhost:3003).
NANGO_DASHBOARD_USERNAME=admin
NANGO_DASHBOARD_PASSWORD=change-me

# Public base URL Nango generates OAuth callback URLs from. Plain localhost is
# fine for providers that accept HTTP loopback redirects (GitHub, Google
# installed-app type); providers that require HTTPS even on localhost need a
# tunnel (ngrok/Cloudflare Tunnel) pointed at this port during dev.
NANGO_SERVER_URL=http://localhost:3003
